# Authentication System Environment Variables
# Copy this file to .env and update the values

# JWT Secret - Used for signing JSON Web Tokens
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Session Secret - Used for session management
SESSION_SECRET=181c6b8a73ce337a2af1cc03a3ff76ff

# Server Configuration
NODE_ENV=development
PORT=3000

# Database Configuration (optional - uses SQLite by default)
# DB_PATH=./users.db

# Security Settings
# CORS_ORIGIN=http://localhost:3000,chrome-extension://*
# COOKIE_SECURE=false

# Note: In production, make sure to:
# 1. Use strong, unique secrets
# 2. Set NODE_ENV=production
# 3. Use HTTPS and set COOKIE_SECURE=true
# 4. Restrict CORS_ORIGIN to your specific domains
