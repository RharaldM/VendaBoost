{
  "manifest_version": 3,
  "name": "VendaBoost",
  "version": "1.0.0",
  "description": "Extensão avançada para automação e agendamento de postagens no Facebook Marketplace com recursos aprimorados de segurança e performance",
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "activeTab",
    "scripting",
    "notifications",
    "webNavigation",
    "identity"
  ],
  "host_permissions": [
    "https://www.facebook.com/*",
    "https://web.facebook.com/*",
    "https://facebook.com/*",
    "https://m.facebook.com/*",
    "https://www.gstatic.com/*",
    "https://firebaseapp.com/*",
    "https://*.firebaseio.com/*",
    "https://*.firebasestorage.app/*",
    "https://*.firestore.googleapis.com/*",
    "https://www.google-analytics.com/*",
    "https://analytics.google.com/*",
    "https://*.google-analytics.com/*",
    "https://region1.google-analytics.com/*",
    "https://api.openai.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.svg",
      "48": "icons/icon48.svg",
      "128": "icons/icon128.svg"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.facebook.com/*", 
        "https://web.facebook.com/*",
        "https://facebook.com/*",
        "https://m.facebook.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end",
      "all_frames": false,
      "type": "module"
    }
  ],
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": [
        "https://www.facebook.com/*",
        "https://web.facebook.com/*",
        "https://facebook.com/*",
        "https://m.facebook.com/*"
      ]
    },
    {
      "resources": ["firebase-config.js", "firebase-integration.js", "chunks/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https://*.googleapis.com https://*.firebaseio.com https://*.firestore.googleapis.com https://*.google-analytics.com wss://*.firebaseio.com https://*.firebasestorage.app https://api.openai.com"
  }
}