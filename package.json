{
  "name": "vendaboost-extension",
  "version": "1.2.4",
  "description": "Advanced browser extension for Facebook Marketplace automation with secure authentication",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "echo 'Build completed - login system only'",
    "build:extension": "vite build && npm run copy:static",
    "copy:static": "node scripts/copy-static.js",
    "preview": "vite preview",
    "setup": "npm install && cd login-system && npm install",
    "setup:auth": "cd login-system && npm run init-db",
    "start": "node app.cjs",
    "start:auth": "cd login-system && npm start",
    "dev:auth": "cd login-system && npm run dev",
    "add:user": "cd login-system && npm run add-user",
    "build:all": "npm run build && cd login-system && npm install --production"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.251",
    "vite": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-session": "^1.18.2",
    "jsonwebtoken": "^9.0.2",
    "sqlite3": "^5.1.6"
  },
  "optionalDependencies": {
    "dexie": "^4.0.11",
    "fs-extra": "^11.2.0"
  }
}
