# IMPORTANTE: Este arquivo não deve conter credenciais sensíveis!
# Configure as variáveis de ambiente no seu provedor de hospedagem

# Configurações do servidor
PORT=7849
NODE_ENV=development

# Configurações do Puppeteer
HEADLESS=false                  # true para modo headless
USER_DATA_DIR=./user-data       # Diretório para sessão persistente
PUPPETEER_CACHE_DIR=./puppeteer-cache  # Cache local do Puppeteer

# Configurações de deploy
NODE_ENV=development
